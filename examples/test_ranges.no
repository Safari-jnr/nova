// Test file for range operators in Nova
// This tests both exclusive (..) and inclusive (..=) ranges

print("=== Testing Exclusive Range (0..5) ===")
for i in 0..5 {
  print(i)
}

print("=== Testing Inclusive Range (1..=3) ===")
for x in 1..=3 {
  print(x)
}

print("=== Testing Negative Range (-2..=2) ===")
for n in -2..=2 {
  print(n)
}

print("=== Testing Single Element Range (5..=5) ===")
for s in 5..=5 {
  print(s)
}

print("=== All range tests completed! ===")
