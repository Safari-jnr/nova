component TasksPage {
  state = {
    tasks: [],
    filter: "all",
    sortBy: "priority"
  }
  
  fn render() {
    print("📋 Rendering Tasks Page...\n")
    
    let ui = view {
      Container(padding: 0, backgroundColor: "#f8f9fa") {
        Container(padding: 30, backgroundColor: "#34495e") {
          Text("Tasks", size: 32, weight: "bold", color: "#ffffff")
          Text("Manage all your tasks in one place", size: 16, color: "#ecf0f1")
        }
        
        Container(padding: 30) {
          Container(margin: 20, padding: 20, backgroundColor: "#ffffff") {
            Text("Filter & Sort", size: 18, weight: "bold")
            
            Container(margin: 15) {
              Button("All Tasks", color: "#3498db")
              Button("In Progress", color: "#f39c12")
              Button("Completed", color: "#2ecc71")
              Button("High Priority", color: "#e74c3c")
            }
          }
          
          Container(margin: 30) {
            Text("Task List", size: 24, weight: "bold")
            
            Container(margin: 20, padding: 20, backgroundColor: "#ffffff") {
              Text("🔴 Design landing page", size: 18, weight: "bold", color: "#e74c3c")
              Text("Project: Website Redesign | Due: Feb 15", size: 14, color: "#7f8c8d")
              Text("Status: In Progress", size: 14, color: "#3498db")
            }
            
            Container(margin: 20, padding: 20, backgroundColor: "#ffffff") {
              Text(" Implement authentication", size: 18, weight: "bold", color: "#e74c3c")
              Text("Project: Backend API | Due: Feb 20", size: 14, color: "#7f8c8d")
              Text("Status: Todo", size: 14, color: "#95a5a6")
            }
            
            Container(margin: 20, padding: 20, backgroundColor: "#ffffff") {
              Text(" Write documentation", size: 18, weight: "bold", color: "#f39c12")
              Text("Project: Backend API | Due: Feb 18", size: 14, color: "#7f8c8d")
              Text("Status: Todo", size: 14, color: "#95a5a6")
            }
            
            Container(margin: 20, padding: 20, backgroundColor: "#e8f8f5") {
              Text(" User testing", size: 18, weight: "bold", color: "#27ae60")
              Text("Project: Website Redesign | Due: Feb 10", size: 14, color: "#7f8c8d")
              Text("Status: Completed", size: 14, color: "#2ecc71")
            }
          }
          
          Container(margin: 20) {
            Button("Add New Task", color: "#2ecc71", size: 18)
            Button("Export List", color: "#95a5a6", size: 16)
          }
        }
      }
    }
    
    print(renderConsole(ui))
    print("\n Tasks page rendered successfully\n")
  }
}

