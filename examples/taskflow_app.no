// ═══════════════════════════════════════════════════════════════════
// PAGE 1: DASHBOARD
// ═══════════════════════════════════════════════════════════════════

component Dashboard {
  state = {
    appName: "TaskFlow",
    user: { name: "Alex Morgan", role: "Project Manager" },
    stats: {
      totalTasks: 6,
      completedTasks: 1,
      inProgressTasks: 2,
      todoTasks: 3,
      totalProjects: 3,
      activeUsers: 1
    },
    recentTasks: []
  }
  
  fn render() {
    print("📱 Rendering Dashboard...\n")
    
    let ui = view {
      Container(padding: 0, backgroundColor: "#f8f9fa") {
        Container(padding: 30, backgroundColor: "#2c3e50") {
          Text(this.state.appName, size: 36, weight: "bold", color: "#ffffff")
          Text("Welcome back, Alex Morgan", size: 18, color: "#ecf0f1")
        }
        
        Container(padding: 30) {
          Text("Dashboard Overview", size: 28, weight: "bold", color: "#2c3e50")
          
          Container(margin: 20) {
            Container(padding: 25, backgroundColor: "#3498db") {
              Text("Total Tasks", size: 16, weight: "bold", color: "#ffffff")
              Text(this.state.stats.totalTasks, size: 42, weight: "bold", color: "#ffffff")
            }
            
            Container(padding: 25, backgroundColor: "#2ecc71") {
              Text("Completed", size: 16, weight: "bold", color: "#ffffff")
              Text(this.state.stats.completedTasks, size: 42, weight: "bold", color: "#ffffff")
            }
            
            Container(padding: 25, backgroundColor: "#e74c3c") {
              Text("In Progress", size: 16, weight: "bold", color: "#ffffff")
              Text(this.state.stats.inProgressTasks, size: 42, weight: "bold", color: "#ffffff")
            }
            
            Container(padding: 25, backgroundColor: "#f39c12") {
              Text("Todo", size: 16, weight: "bold", color: "#ffffff")
              Text(this.state.stats.todoTasks, size: 42, weight: "bold", color: "#ffffff")
            }
          }
          
          Container(margin: 30, padding: 25, backgroundColor: "#ffffff") {
            Text("Recent Tasks", size: 22, weight: "bold", color: "#2c3e50")
            
            Container(margin: 15) {
              Text("✓ Design landing page (In Progress)", size: 16, color: "#3498db")
              Text("• Implement authentication (Todo)", size: 16, color: "#95a5a6")
              Text("• Bug fixes (In Progress)", size: 16, color: "#3498db")
            }
          }
          
          Container(margin: 20) {
            Button("View All Tasks", color: "#3498db", size: 16)
            Button("New Task", color: "#2ecc71", size: 16)
          }
        }
      }
    }
    
    print(renderConsole(ui))
    print("\n✅ Dashboard rendered successfully\n")
  }
}

let dashboard = Dashboard()
dashboard.render()

print("─────────────────────────────────────────────────────\n")

